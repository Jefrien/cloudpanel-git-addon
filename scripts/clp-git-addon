#!/bin/bash
set -e

# CloudPanel Git Addon - Git Management
# https://github.com/Jefrien/cloudpanel-git-addon

ADDON_DIR="/opt/clp-git-addon"
CLP_APP="/home/clp/htdocs/app/files"
CLP_TEMPLATES="$CLP_APP/templates/Frontend/Site"
CLP_CONTROLLERS="$CLP_APP/src/Controller/Frontend"
CLP_CSS="$CLP_APP/public/assets/css/frontend"
CLP_ROUTES="$CLP_APP/config/routes.yaml"
TAB_TEMPLATE="$CLP_TEMPLATES/Partial/tab-container.html.twig"

WEBHOOK_DIR="$ADDON_DIR/bin"
WEBHOOK_BIN="$WEBHOOK_DIR/webhook"
WEBHOOK_CONFIG_DIR="$ADDON_DIR/config"
WEBHOOK_HOOKS="$WEBHOOK_CONFIG_DIR/webhook-hooks.json"
WEBHOOK_SERVICE="/etc/systemd/system/clp-git-webhook.service"
WEBHOOK_PORT="9000"
LOGS_DIR="$ADDON_DIR/logs"

VERSION_FILE="$ADDON_DIR/VERSION"
VERSION=$(cat "$VERSION_FILE" 2>/dev/null || echo "unknown")

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_ok()   { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err()  { echo -e "${RED}[ERROR]${NC} $1"; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log_err "This script must be run as root."
        exit 1
    fi
}

is_patched() {
    grep -q "clp_site_git" "$CLP_ROUTES" 2>/dev/null && \
    grep -q "'git'" "$TAB_TEMPLATE" 2>/dev/null
}

is_webhook_installed() {
    [ -f "$WEBHOOK_BIN" ] && \
    [ -f "$WEBHOOK_HOOKS" ] && \
    [ -f "$WEBHOOK_SERVICE" ] && \
    systemctl is-active --quiet clp-git-webhook.service 2>/dev/null
}

patch_tab_container() {
    if grep -q "'git'" "$TAB_TEMPLATE" 2>/dev/null; then
        log_ok "Tab already present in tab-container.html.twig"
        return 0
    fi

    # Insert git tab before closing </ul>
    sed -i '/<\/ul>/i\    <li {% if active == '\''git'\'' %}class="active"{% endif %}>\n      <a href="{{ path('\''clp_site_git'\'', {'\''domainName'\'': site.domainName}) }}">{% trans %}Git{% endtrans %}<\/a>\n    <\/li>' "$TAB_TEMPLATE"

    if grep -q "'git'" "$TAB_TEMPLATE"; then
        log_ok "Tab added to tab-container.html.twig"
    else
        log_err "Failed to patch tab-container.html.twig"
        return 1
    fi
}

unpatch_routes() {
    # Remove the CloudPanel Git Addon route block using explicit start/end markers.
    # This prevents duplicate keys even if previous patches left malformed blocks.
    awk '
        BEGIN { skip = 0 }
        /# === CloudPanel Git Addon routes start ===/ { skip = 1; next }
        /# === CloudPanel Git Addon routes end ===/ { skip = 0; next }
        !skip { print }
    ' "$CLP_ROUTES" > "$CLP_ROUTES.tmp" && mv "$CLP_ROUTES.tmp" "$CLP_ROUTES"

    # Also remove legacy entries that may still exist from older versions
    grep -v '^# CloudPanel Git Addon' "$CLP_ROUTES" | \
    grep -vE '^clp_site_git(_[a-z0-9_]+)?:' > "$CLP_ROUTES.tmp" && \
    mv "$CLP_ROUTES.tmp" "$CLP_ROUTES"
}

patch_routes() {
    # Always remove existing entries first to ensure a clean, non-duplicated block
    unpatch_routes

    cat >> "$CLP_ROUTES" << 'ROUTES'

# === CloudPanel Git Addon routes start ===
# CloudPanel Git Addon - Git Management
clp_site_git:
  path: /site/{domainName}/git
  controller: App\Controller\Frontend\GitController::index

clp_site_git_generate_key:
  path: /site/{domainName}/git/generate-key
  controller: App\Controller\Frontend\GitController::generateKey

clp_site_git_test_connection:
  path: /site/{domainName}/git/test-connection
  controller: App\Controller\Frontend\GitController::testGit

clp_site_git_save_config:
  path: /site/{domainName}/git/save-config
  controller: App\Controller\Frontend\GitController::saveGitConfig

clp_site_git_deploy_logs:
  path: /site/{domainName}/git/deploy-logs
  controller: App\Controller\Frontend\GitController::getDeployLogs

clp_site_git_trigger_deploy:
  path: /site/{domainName}/git/trigger-deploy
  controller: App\Controller\Frontend\GitController::triggerDeploy
# === CloudPanel Git Addon routes end ===
ROUTES

    if grep -q "clp_site_git:" "$CLP_ROUTES"; then
        log_ok "Routes added to routes.yaml"
    else
        log_err "Failed to patch routes.yaml"
        return 1
    fi
}

copy_files() {
    cp "$ADDON_DIR/src/Controller/Frontend/GitController.php" "$CLP_CONTROLLERS/GitController.php"
    cp "$ADDON_DIR/templates/Frontend/Site/git.html.twig" "$CLP_TEMPLATES/git.html.twig"

    # Copy Git partial templates
    mkdir -p "$CLP_TEMPLATES/Partial/Git"
    cp "$ADDON_DIR/templates/Frontend/Site/Partial/Git/"*.twig "$CLP_TEMPLATES/Partial/Git/"

    # Ensure correct ownership (CloudPanel files are owned by clp:clp)
    chown clp:clp "$CLP_CONTROLLERS/GitController.php"
    chown clp:clp "$CLP_TEMPLATES/git.html.twig"
    chown -R clp:clp "$CLP_TEMPLATES/Partial/Git"
    chown clp:clp "$ADDON_DIR/scripts/clp-git-deploy-wrapper.sh"

    # Match CloudPanel file permissions (750)
    chmod 770 "$CLP_CONTROLLERS/GitController.php"
    chmod 770 "$CLP_TEMPLATES/git.html.twig"
    chmod -R 770 "$CLP_TEMPLATES/Partial/Git"
    chmod 770 "$ADDON_DIR/scripts/clp-git-deploy-wrapper.sh"

    log_ok "Addon files copied"
}

clear_cache() {
    if su -s /bin/bash -c "cd $CLP_APP && php bin/console cache:clear --env=prod 2>&1" clp > /dev/null; then
        log_ok "Symfony cache cleared"
    else
        log_warn "Symfony cache clear failed (continuing anyway)"
    fi
}

install_apt_hook() {
    local hook_file="/etc/apt/apt.conf.d/99-clp-git-addon"

    cat > "$hook_file" << 'HOOK'
DPkg::Post-Invoke { "if [ -x /usr/local/bin/clp-git-addon ]; then /usr/local/bin/clp-git-addon repair --quiet 2>/dev/null || true; fi"; };
HOOK

    log_ok "APT hook installed at $hook_file"
}

install_webhook_binary() {
    if [ -f "$WEBHOOK_BIN" ]; then
        log_ok "Webhook binary already present at $WEBHOOK_BIN"
        return 0
    fi

    echo "Downloading latest webhook release from GitHub..."

    # Auto-detect architecture, defaulting to amd64
    local arch
    arch=$(uname -m)
    case "$arch" in
        x86_64)  arch_suffix='linux-amd64' ;;
        aarch64) arch_suffix='linux-arm64' ;;
        armv7l)  arch_suffix='linux-arm' ;;
        *)       arch_suffix='linux-amd64' ;;
    esac

    local asset_url
    asset_url=$(curl -sL -A 'clp-git-addon' https://api.github.com/repos/adnanh/webhook/releases/latest | \
        grep -oP '"browser_download_url":\s*"\K[^"]+' | \
        grep "$arch_suffix.tar.gz" | \
        head -1)

    if [ -z "$asset_url" ]; then
        log_err "Could not determine latest webhook download URL for architecture: $arch_suffix"
        return 1
    fi

    log_ok "Resolved download URL: $asset_url"

    local tmp_dir
    tmp_dir=$(mktemp -d)
    local tarball="$tmp_dir/webhook.tar.gz"

    if ! curl -sL -A 'clp-git-addon' "$asset_url" -o "$tarball"; then
        log_err "Failed to download webhook tarball"
        rm -rf "$tmp_dir"
        return 1
    fi

    if [ ! -s "$tarball" ]; then
        log_err "Downloaded webhook tarball is empty"
        rm -rf "$tmp_dir"
        return 1
    fi

    mkdir -p "$WEBHOOK_DIR"
    if ! tar xzf "$tarball" -C "$tmp_dir"; then
        log_err "Failed to extract webhook tarball"
        file "$tarball"
        rm -rf "$tmp_dir"
        return 1
    fi

    # The tarball may contain the binary at the root or inside a subdirectory
    local extracted_bin
    extracted_bin=$(find "$tmp_dir" -type f -name 'webhook' | head -n 1)

    if [ -z "$extracted_bin" ]; then
        log_err "Could not find webhook binary in downloaded archive"
        echo "Extracted contents:"
        find "$tmp_dir" -type f -o -type d
        rm -rf "$tmp_dir"
        return 1
    fi

    cp "$extracted_bin" "$WEBHOOK_BIN"
    chmod +x "$WEBHOOK_BIN"
    rm -rf "$tmp_dir"

    # Symlink into /usr/local/bin so it's available in PATH
    ln -sf "$WEBHOOK_BIN" /usr/local/bin/webhook

    log_ok "Webhook binary installed at $WEBHOOK_BIN"
}

install_webhook_hooks() {
    mkdir -p "$WEBHOOK_CONFIG_DIR"

    # Ensure the clp user can read and write hooks configuration
    chown -R clp:clp "$WEBHOOK_CONFIG_DIR"
    chmod 750 "$WEBHOOK_CONFIG_DIR"

    if [ ! -f "$WEBHOOK_HOOKS" ]; then
        cat > "$WEBHOOK_HOOKS" << 'HOOKS'
[]
HOOKS
    fi

    chown clp:clp "$WEBHOOK_HOOKS"
    chmod 640 "$WEBHOOK_HOOKS"

    # Ensure deploy logs directory exists and is writable by the webhook service (clp)
    mkdir -p "$LOGS_DIR"
    chown -R clp:clp "$LOGS_DIR"
    chmod 755 "$LOGS_DIR"

    # Reload the webhook service so it picks up any hooks file changes
    if systemctl is-active --quiet clp-git-webhook.service 2>/dev/null; then
        systemctl restart clp-git-webhook.service
    fi

    log_ok "Webhook hooks file ready at $WEBHOOK_HOOKS"
}

install_webhook_service() {
    cat > "$WEBHOOK_SERVICE" << SERVICE
[Unit]
Description=CloudPanel Git Addon Webhook
After=network.target

[Service]
Type=simple
User=root
Group=root
ExecStart=$WEBHOOK_BIN -hooks $WEBHOOK_HOOKS -port $WEBHOOK_PORT -hotreload -nopanic -logfile $LOGS_DIR/webhook.log
Restart=on-failure

[Install]
WantedBy=multi-user.target
SERVICE

    systemctl daemon-reload

    if systemctl is-enabled --quiet clp-git-webhook.service 2>/dev/null; then
        log_ok "Webhook service already enabled"
    else
        systemctl enable clp-git-webhook.service
        log_ok "Webhook service enabled"
    fi

    if systemctl is-active --quiet clp-git-webhook.service 2>/dev/null; then
        systemctl restart clp-git-webhook.service
        log_ok "Webhook service restarted"
    else
        systemctl start clp-git-webhook.service
        log_ok "Webhook service started"
    fi
}

uninstall_webhook() {
    if systemctl is-active --quiet clp-git-webhook.service 2>/dev/null; then
        systemctl stop clp-git-webhook.service
    fi

    if systemctl is-enabled --quiet clp-git-webhook.service 2>/dev/null; then
        systemctl disable clp-git-webhook.service
    fi

    rm -f "$WEBHOOK_SERVICE"
    rm -f "$WEBHOOK_BIN"
    rm -f /usr/local/bin/webhook
    rm -f "$WEBHOOK_HOOKS"

    systemctl daemon-reload

    log_ok "Webhook service and binary removed"
}

cmd_install() {
    check_root
    echo "Installing CloudPanel Git Addon v$VERSION..."
    echo ""

    if [ ! -d "$ADDON_DIR" ]; then
        log_err "Addon source not found at $ADDON_DIR"
        log_err "Please clone the repository to $ADDON_DIR first."
        exit 1
    fi

    if [ ! -d "$CLP_APP" ]; then
        log_err "CloudPanel not found at $CLP_APP"
        exit 1
    fi

    copy_files
    patch_tab_container
    patch_routes
    clear_cache
    install_apt_hook
    install_webhook_binary
    install_webhook_hooks
    install_webhook_service

    # Install this script to /usr/local/bin
    cp "$ADDON_DIR/scripts/clp-git-addon" /usr/local/bin/clp-git-addon
    chmod +x /usr/local/bin/clp-git-addon

    echo ""
    log_ok "Installation complete!"
    echo ""
    echo "  Open CloudPanel and navigate to any site."
    echo "  You should see a new 'Git' tab."
    echo ""
}

cmd_update() {
    check_root
    echo "Checking for latest CloudPanel Git Addon tag..."
    echo ""

    # GitHub tags API (works even when no GitHub Releases are created)
    local latest_tag
    latest_tag=$(curl -sL -A 'clp-git-addon' https://api.github.com/repos/Jefrien/cloudpanel-git-addon/tags | \
        grep -oP '"name":\s*"\K[^"]+' | \
        head -n 1)

    if [ -z "$latest_tag" ]; then
        log_err "Could not determine latest tag from GitHub"
        exit 1
    fi

    log_ok "Latest tag: $latest_tag"

    local current_version
    current_version=$(cat "$ADDON_DIR/VERSION" 2>/dev/null || echo "unknown")

    if [ "$current_version" = "${latest_tag#v}" ]; then
        log_ok "Already running the latest version ($latest_tag)"
        return 0
    fi

    echo "Current version: v$current_version"
    echo "Updating to $latest_tag..."
    echo ""

    local download_url="https://github.com/Jefrien/cloudpanel-git-addon/archive/refs/tags/${latest_tag}.tar.gz"
    local tmp_dir
    tmp_dir=$(mktemp -d)
    local tarball="$tmp_dir/cloudpanel-git-addon.tar.gz"

    if ! curl -sL -A 'clp-git-addon' "$download_url" -o "$tarball"; then
        log_err "Failed to download release tarball"
        rm -rf "$tmp_dir"
        exit 1
    fi

    if [ ! -s "$tarball" ]; then
        log_err "Downloaded tarball is empty"
        rm -rf "$tmp_dir"
        exit 1
    fi

    # Backup current installation
    local backup_dir="$ADDON_DIR.backup.$(date +%Y%m%d%H%M%S)"
    echo "Creating backup at $backup_dir..."
    cp -a "$ADDON_DIR" "$backup_dir"

    # Extract new release
    tar xzf "$tarball" -C "$tmp_dir"

    local extracted_dir
    extracted_dir=$(find "$tmp_dir" -maxdepth 1 -type d -name 'cloudpanel-git-addon-*' | head -n 1)

    if [ -z "$extracted_dir" ]; then
        log_err "Could not find extracted addon directory"
        rm -rf "$tmp_dir"
        exit 1
    fi

    # Replace addon files
    echo "Replacing addon files..."
    cp -a "${extracted_dir}"/* "$ADDON_DIR/"

    # GitHub tarballs may not preserve executable permissions; restore them
    chmod +x "$ADDON_DIR/scripts/clp-git-addon"
    chmod +x "$ADDON_DIR/bump-version.sh"

    # Ensure shell scripts use Unix line endings (GitHub tarballs sometimes contain CRLF)
    for script in "$ADDON_DIR/scripts/clp-git-addon" "$ADDON_DIR/bump-version.sh" "$ADDON_DIR/scripts/clp-git-deploy-wrapper.sh"; do
        if [ -f "$script" ]; then
            tr -d '\r' < "$script" > "$script.tmp"
            mv "$script.tmp" "$script"
            chmod +x "$script"
        fi
    done

    # Cleanup
    rm -rf "$tmp_dir"

    log_ok "Addon source updated to $latest_tag"
    echo ""

    # Re-run install to apply changes
    cmd_install

    echo ""
    log_ok "Update complete! Backup kept at $backup_dir"
}

cmd_repair() {
    check_root

    local quiet=false
    [ "$1" = "--quiet" ] && quiet=true

    if [ ! -d "$ADDON_DIR" ]; then
        $quiet || log_err "Addon source not found at $ADDON_DIR - cannot repair."
        return 1
    fi

    # If everything is in place, only re-apply permissions and clear cache.
    # This fixes webhook hooks/log directory ownership/permissions issues
    # without re-running the full patch sequence.
    if is_patched && \
       [ -f "$CLP_CONTROLLERS/GitController.php" ] && \
       [ -f "$CLP_TEMPLATES/git.html.twig" ] && \
       [ -d "$CLP_TEMPLATES/Partial/Git" ] && \
       is_webhook_installed; then
        $quiet || echo "All patches intact, re-applying permissions..."
        copy_files
        clear_cache
        install_webhook_hooks
        install_webhook_service
        $quiet || log_ok "Permissions re-applied."
        return 0
    fi

    $quiet || echo "Repairing CloudPanel Git Addon..."

    copy_files
    patch_tab_container
    patch_routes
    clear_cache
    install_webhook_binary
    install_webhook_hooks
    install_webhook_service

    $quiet || log_ok "Repair complete!"
}

cmd_check() {
    echo "Checking CloudPanel Git Addon status..."
    echo ""

    local all_ok=true

    if [ -f "$CLP_CONTROLLERS/GitController.php" ]; then
        log_ok "GitController.php present"
    else
        log_err "GitController.php MISSING"
        all_ok=false
    fi

    if [ -f "$CLP_TEMPLATES/git.html.twig" ]; then
        log_ok "git.html.twig present"
    else
        log_err "git.html.twig MISSING"
        all_ok=false
    fi

    if [ -d "$CLP_TEMPLATES/Partial/Git" ]; then
        log_ok "Git partial templates present"
    else
        log_err "Git partial templates MISSING"
        all_ok=false
    fi

    if grep -q "clp_site_git" "$CLP_ROUTES" 2>/dev/null; then
        log_ok "Routes configured"
    else
        log_err "Routes MISSING"
        all_ok=false
    fi

    if grep -q "'git'" "$TAB_TEMPLATE" 2>/dev/null; then
        log_ok "Git tab present"
    else
        log_err "Git tab MISSING"
        all_ok=false
    fi

    if [ -f "/etc/apt/apt.conf.d/99-clp-git-addon" ]; then
        log_ok "APT hook installed"
    else
        log_warn "APT hook not installed"
    fi

    if [ -f "$WEBHOOK_BIN" ]; then
        log_ok "Webhook binary present"
    else
        log_err "Webhook binary MISSING"
        all_ok=false
    fi

    if [ -f "$WEBHOOK_HOOKS" ]; then
        log_ok "Webhook hooks file present"
    else
        log_err "Webhook hooks file MISSING"
        all_ok=false
    fi

    if [ -f "$WEBHOOK_SERVICE" ]; then
        if systemctl is-active --quiet clp-git-webhook.service 2>/dev/null; then
            log_ok "Webhook service is running"
        else
            log_err "Webhook service is NOT running"
            all_ok=false
        fi
    else
        log_err "Webhook service file MISSING"
        all_ok=false
    fi

    if [ -d "$LOGS_DIR" ]; then
        log_ok "Deploy logs directory present"
    else
        log_warn "Deploy logs directory not present"
    fi

    echo ""
    if $all_ok; then
        log_ok "Everything looks good!"
    else
        log_err "Issues detected. Run 'clp-git-addon repair' to fix."
    fi
}

cmd_uninstall() {
    check_root
    echo "Uninstalling CloudPanel Git Addon..."

    # Remove addon files from CloudPanel
    rm -f "$CLP_CONTROLLERS/GitController.php"
    rm -f "$CLP_TEMPLATES/git.html.twig"
    rm -rf "$CLP_TEMPLATES/Partial/Git"

    # Remove routes
    unpatch_routes

    # Remove tab from template
    sed -i "/git/d" "$TAB_TEMPLATE"

    # Remove APT hook
    rm -f /etc/apt/apt.conf.d/99-clp-git-addon

    # Remove webhook service and binary
    uninstall_webhook

    # Clear cache
    clear_cache

    log_ok "Addon removed from CloudPanel."
    log_warn "Addon source at $ADDON_DIR was NOT removed."
    log_warn "To remove completely: rm -rf $ADDON_DIR /usr/local/bin/clp-git-addon"
}

case "${1:-}" in
    install)
        cmd_install
        ;;
    update)
        cmd_update
        ;;
    repair)
        cmd_repair "${2:-}"
        ;;
    check)
        cmd_check
        ;;
    uninstall)
        cmd_uninstall
        ;;
    *)
        echo "CloudPanel Git Addon - Git Management"
        echo ""
        echo "Usage: clp-git-addon <command>"
        echo ""
        echo "Commands:"
        echo "  install     Install the addon into CloudPanel"
        echo "  update      Download and install the latest release from GitHub"
        echo "  repair      Re-apply patches (e.g., after CloudPanel update)"
        echo "  check       Verify addon status"
        echo "  uninstall   Remove addon from CloudPanel"
        echo ""
        ;;
esac
